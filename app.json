{
  "expo": {
    "name": "test",
    "slug": "test",
    "version": "1.0.0",
    "scheme": "test",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./src/assets/icons/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daniel15898.test"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.daniel15898.test"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a18cb3bf-f3df-4c3f-869e-148c1bcf54c2"
      }
    }
  }
}
